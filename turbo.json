{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["TMDB_API_TOKEN"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".nitro/**", ".tanstack/**", ".vercel/**", ".output/**"]
    },
    "lint": {
      "outputs": [".eslintcache"]
    },
    "format": {},
    "typecheck": {},
    "test": {
      "cache": false,
      "persistent": true
    },
    "coverage": {
      "outputs": ["coverage/**"]
    },
    "e2e": {
      "dependsOn": ["build"],
      "passThroughEnv": ["CI", "TMDB_API_TOKEN"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "e2e:ui": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "knip": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
