{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "sortTailwindcss": {
    "stylesheet": "./src/styles/global.css"
  },
  "printWidth": 80,
  "quoteProps": "consistent",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "experimentalSortPackageJson": {},
  "ignorePatterns": [
    "**/pnpm-lock.yaml",
    "CHANGELOG.md",
    "*.gen.*",
    "**/gen/**/index.ts"
  ]
}
